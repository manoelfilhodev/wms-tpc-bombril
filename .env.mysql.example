APP_NAME=Systex WMS
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://your-domain.example
API_DOCS_ENABLED=false

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wms
DB_USERNAME=wms_app
DB_PASSWORD=wms_app_local
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Rotas de expedição (opcional)
EXPEDICAO_ROTAS_PROVIDER=osrm
GOOGLE_MAPS_API_KEY=
EXPEDICAO_ROTAS_ENDPOINT=https://maps.googleapis.com/maps/api/distancematrix/json
EXPEDICAO_ROTAS_OSRM_ENDPOINT=https://router.project-osrm.org/route/v1/driving
EXPEDICAO_ROTAS_GEOCODE_ENDPOINT=https://nominatim.openstreetmap.org/search
EXPEDICAO_ROTAS_ORIGIN_CITY="Sao Bernardo do Campo"
EXPEDICAO_ROTAS_ORIGIN_UF=SP
EXPEDICAO_ROTAS_ORIGIN_ADDRESS="Bombril, Sao Bernardo do Campo, SP, Brasil"
EXPEDICAO_ROTAS_COUNTRY=Brasil
EXPEDICAO_ROTAS_CACHE_DAYS=30
EXPEDICAO_ROTAS_RECALCULATE_PER_REQUEST=2
EXPEDICAO_ROTAS_TIMEOUT=5
EXPEDICAO_ROTAS_RETRY_TIMES=1
EXPEDICAO_ROTAS_USER_AGENT="${APP_NAME} - ${APP_URL}"
